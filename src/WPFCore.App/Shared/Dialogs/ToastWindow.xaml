<Window x:Class="WPFCore.App.Shared.Dialogs.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Toast" 
        SizeToContent="WidthAndHeight"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True" ResizeMode="NoResize"
        IsHitTestVisible="False" ShowActivated="False"
        Style="{x:Null}">

    <!-- Animation trượt từ dưới lên và mờ dần khi hiện ra -->
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
                    <ThicknessAnimation Storyboard.TargetProperty="Margin" From="0,30,0,0" To="0,0,0,0" Duration="0:0:0.3">
                        <ThicknessAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </ThicknessAnimation.EasingFunction>
                    </ThicknessAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid Margin="15">
        <Border Background="#333333" CornerRadius="8" Padding="16,12" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.4" Direction="270"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <!-- Icon nhỏ (nếu có thư viện icon, ở đây tạm dùng Text) -->
                <TextBlock Text="✓" Foreground="#4CAF50" FontWeight="Bold" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="MessageText" Text="Message goes here" Foreground="White" FontSize="14" VerticalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
