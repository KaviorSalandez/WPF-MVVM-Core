<Window x:Class="WPFCore.App.Shell.Login.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFCore.App.Shell.Login"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=local:LoginViewModel}"
        Title="Đăng nhập — WPFCore"
        Width="820" Height="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Nút đóng (X) góc trên-phải -->
        <Style x:Key="FlatCloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3D4A5C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#526070"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PasswordBox style khớp với theme Windows11Light -->
        <Style x:Key="LoginPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="CaretBrush" Value="#3B82F6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="OuterBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#CBD5E1"
                                BorderThickness="1"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter TargetName="OuterBorder" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#94A3B8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Nút Đăng nhập — gradient xanh nổi bật -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="8">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#2563EB" Offset="0"/>
                                    <GradientStop Color="#4F46E5" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="14" ShadowDepth="0"
                                                  Color="#2563EB" Opacity="0.38"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.72"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer border: CornerRadius + DropShadow (AllowsTransparency cho phép shadow ra ngoài window) -->
    <Border CornerRadius="12" Background="White"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="36" ShadowDepth="0"
                              Color="#000000" Opacity="0.18"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══════════════════════════════════════
                 LEFT PANEL — Branding / accent tối
                 ═══════════════════════════════════════ -->
            <Border Grid.Column="0" CornerRadius="12,0,0,12" ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0F172A" Offset="0"/>
                        <GradientStop Color="#1E3A5F" Offset="0.55"/>
                        <GradientStop Color="#1D4ED8" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <!-- Vòng trang trí góc trên-phải -->
                    <Ellipse Width="200" Height="200"
                             HorizontalAlignment="Right" VerticalAlignment="Top"
                             Margin="0,-80,-80,0" Opacity="0.06">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="White" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <!-- Vòng trang trí góc dưới-trái -->
                    <Ellipse Width="160" Height="160"
                             HorizontalAlignment="Left" VerticalAlignment="Bottom"
                             Margin="-60,0,0,-60" Opacity="0.05">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="White" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <!-- Nội dung branding -->
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Margin="32,0">

                        <!-- Icon ứng dụng -->
                        <Border Width="70" Height="70" CornerRadius="20"
                                HorizontalAlignment="Center" Margin="0,0,0,22">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#3B82F6" Offset="0"/>
                                    <GradientStop Color="#6366F1" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="18" ShadowDepth="0"
                                                  Color="#3B82F6" Opacity="0.55"/>
                            </Border.Effect>
                            <TextBlock Text="W" FontSize="36" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="WPFCore" FontSize="26" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"/>

                        <TextBlock Text="Desktop Boilerplate" FontSize="13"
                                   Foreground="#64748B" HorizontalAlignment="Center"
                                   Margin="0,5,0,0"/>

                        <Rectangle Height="1" Fill="#FFFFFF" Opacity="0.09"
                                   Margin="0,26,0,26"/>

                        <TextBlock TextWrapping="Wrap" TextAlignment="Center"
                                   FontSize="12.5" Foreground="#475569"
                                   LineHeight="22">
                            Hệ thống quản lý dữ liệu&#10;khách hàng dành cho&#10;doanh nghiệp
                        </TextBlock>
                    </StackPanel>

                    <!-- Phiên bản ở đáy -->
                    <TextBlock Text="v1.0.0  ·  © 2026 WPFCore Team"
                               Foreground="#334155" FontSize="10"
                               HorizontalAlignment="Center" VerticalAlignment="Bottom"
                               Margin="0,0,0,18"/>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════
                 RIGHT PANEL — Form đăng nhập
                 ═══════════════════════════════════════ -->
            <Grid Grid.Column="1" Background="#F8FAFC">
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Top bar: nút đóng -->
                <Grid Grid.Row="0">
                    <Button Style="{StaticResource FlatCloseButtonStyle}"
                            Content="✕" FontSize="12" Foreground="#94A3B8"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Margin="0,0,12,0"
                            Click="CloseButton_Click"/>
                </Grid>

                <!-- Form content -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center"
                            Margin="48,0,48,28">

                    <TextBlock Text="Chào mừng trở lại" FontSize="26" FontWeight="Bold"
                               Foreground="#0F172A" Margin="0,0,0,5"/>
                    <TextBlock Text="Vui lòng đăng nhập để tiếp tục sử dụng hệ thống."
                               FontSize="13" Foreground="#64748B"
                               TextWrapping="Wrap" Margin="0,0,0,34"/>

                    <!-- Tên đăng nhập -->
                    <TextBlock Text="Tên đăng nhập" FontSize="13" FontWeight="SemiBold"
                               Foreground="#374151" Margin="0,0,0,6"/>
                    <syncfusion:SfTextBoxExt
                        x:Name="UsernameBox"
                        Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                        Watermark="Nhập tên đăng nhập..."
                        FontSize="14" Height="42"
                        Margin="0,0,0,18"
                        KeyDown="UsernameBox_KeyDown"/>

                    <!-- Mật khẩu -->
                    <TextBlock Text="Mật khẩu" FontSize="13" FontWeight="SemiBold"
                               Foreground="#374151" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="PasswordBox"
                                 Style="{StaticResource LoginPasswordBoxStyle}"
                                 Margin="0,0,0,6"/>

                    <!-- Thông báo lỗi -->
                    <Border Background="#FEF2F2" CornerRadius="6" Padding="10,8"
                            Margin="0,0,0,14"
                            Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠" Foreground="#EF4444" FontSize="13"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding ErrorMessage}"
                                       FontSize="12.5" Foreground="#B91C1C"
                                       VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Nút đăng nhập -->
                    <Button Content="Đăng nhập"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding LoginCommand}"
                            Height="44" FontSize="14" FontWeight="SemiBold"
                            Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
