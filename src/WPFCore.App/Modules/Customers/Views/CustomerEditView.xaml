<UserControl x:Class="WPFCore.App.Modules.Customers.Views.CustomerEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:WPFCore.App.Modules.Customers.ViewModels"
             xmlns:converters="clr-namespace:WPFCore.App.Shared.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:CustomerEditViewModel}"
             d:DesignHeight="500" d:DesignWidth="600">
    <UserControl.Resources>
        <converters:DateOnlyToDateTimeConverter x:Key="DateOnlyToDateTimeConverter" />
    </UserControl.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16" />

        <syncfusion:SfBusyIndicator Grid.Row="1" IsBusy="{Binding IsBusy}" />

        <StackPanel Grid.Row="2" Orientation="Vertical">
            <Grid Margin="0,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Mã khách hàng" VerticalAlignment="Center" />
                <syncfusion:SfTextBoxExt Grid.Row="0" Grid.Column="1" x:Name="CodeInput" Validation.ErrorTemplate="{x:Null}"
                                          Text="{Binding Code, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, NotifyOnValidationError=True}"
                                          MaxLength="10" CharacterCasing="Upper" MinHeight="36" VerticalContentAlignment="Center"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Foreground="Red" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"
                           Text="{Binding ElementName=CodeInput, Path=(Validation.Errors)[0].ErrorContent}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=CodeInput, Path=(Validation.HasError)}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <Grid Margin="0,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Tên khách hàng *" VerticalAlignment="Center" />
                <syncfusion:SfTextBoxExt Grid.Row="0" Grid.Column="1" x:Name="NameInput" Validation.ErrorTemplate="{x:Null}"
                                          Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, NotifyOnValidationError=True}" MinHeight="36" VerticalContentAlignment="Center"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Foreground="Red" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"
                           Text="{Binding ElementName=NameInput, Path=(Validation.Errors)[0].ErrorContent}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=NameInput, Path=(Validation.HasError)}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <Grid Margin="0,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Email" VerticalAlignment="Center" />
                <syncfusion:SfTextBoxExt Grid.Row="0" Grid.Column="1" x:Name="EmailInput" Validation.ErrorTemplate="{x:Null}"
                                          Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, NotifyOnValidationError=True}" MinHeight="36" VerticalContentAlignment="Center"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Foreground="Red" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"
                           Text="{Binding ElementName=EmailInput, Path=(Validation.Errors)[0].ErrorContent}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=EmailInput, Path=(Validation.HasError)}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <Grid Margin="0,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Số điện thoại" VerticalAlignment="Center" />
                <syncfusion:SfTextBoxExt Grid.Row="0" Grid.Column="1" x:Name="PhoneInput" Validation.ErrorTemplate="{x:Null}"
                                          Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, NotifyOnValidationError=True}" MinHeight="36" VerticalContentAlignment="Center"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Foreground="Red" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"
                           Text="{Binding ElementName=PhoneInput, Path=(Validation.Errors)[0].ErrorContent}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=PhoneInput, Path=(Validation.HasError)}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <Grid Margin="0,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Địa chỉ" VerticalAlignment="Center" />
                <syncfusion:SfTextBoxExt Grid.Row="0" Grid.Column="1" x:Name="AddressInput" Validation.ErrorTemplate="{x:Null}"
                                          Text="{Binding Address, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, NotifyOnValidationError=True}"
                                          TextWrapping="Wrap" AcceptsReturn="True" Height="60" VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Center"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Foreground="Red" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"
                           Text="{Binding ElementName=AddressInput, Path=(Validation.Errors)[0].ErrorContent}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=AddressInput, Path=(Validation.HasError)}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Ngày sinh" VerticalAlignment="Center" />
                <DatePicker Grid.Column="1" SelectedDate="{Binding DateOfBirth, Converter={StaticResource DateOnlyToDateTimeConverter}}" MinHeight="36" VerticalContentAlignment="Center"/>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Hủy" Command="{Binding CancelCommand}" Width="80" Margin="0,0,8,0" Padding="8,4" />
            <Button Content="Lưu" Command="{Binding SaveCommand}" Width="80" Padding="8,4" />
        </StackPanel>
    </Grid>
</UserControl>
