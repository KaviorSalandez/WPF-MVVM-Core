{
  "App": {
    "Name": "WPFCore",
    "Version": "1.0.0",
    "Environment": "Production",
    "SeedData": {
      "Enabled": true,
      "CustomerCount": 10
    },
    "Paths": {
      "Database": "WPFCore/wpfcore.db",
      "Logs": "WPFCore/logs"
    }
  },
  "Database": {
    "ConnectionStringName": "Default",
    "EnableWal": true,
    "AutoMigrate": true
  },
  "Syncfusion": {
    "LicenseKey": "Ngo9BigBOggjHTQxAR8/V1NAaF1cWmhIfEx1RHxQdld5ZFRHallYTnNWUj0eQnxTdEFjW31ccnRRRmBcVUxwXg==",
    "Theme": "Windows11Light"
  },
  "ConnectionStrings": {
    "Default": "Data Source=wpfcore.db"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.File", "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/wpfcore-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext} {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  }
}
